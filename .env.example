# ────────────────────────────────────────────────────────────
# DYData 环境变量模板
# 复制本文件为 .env.local 后填入真实值；× commit 到 git
# ────────────────────────────────────────────────────────────

# ── Supabase 公开配置（前端可见） ──
NEXT_PUBLIC_SUPABASE_URL=https://mkkvnogkqcupvxmnoefy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase Dashboard → Project Settings → API → anon public>

# ── Supabase 服务端密钥 ──
# 用途：服务端 API 路由、cron 接口、绕 RLS 读写
# 限制：× 能执行 DDL（建表/建函数/改 schema）
SUPABASE_SERVICE_ROLE_KEY=<Supabase Dashboard → Project Settings → API → service_role>

# ── Supabase 数据库直连串（DDL 通道，Win/Codex 必填） ──
# 用途：psql 或 node-pg 直接执行 migration、临时 SQL
# 来源：Dashboard 顶部 Connect 按钮 → Connection string → Session pooler → URI
# 密码：Project Settings → Database → Database Password（忘了就 Reset）
# 安全：等同库的钥匙，× 上传 git，× 明文丢桌面，泄露立即重置
SUPABASE_DB_URL=postgresql://postgres.mkkvnogkqcupvxmnoefy:<DB_PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Supabase Personal Access Token（CLI migration 通道，可选） ──
# 用途：supabase CLI 推 migrations、查 schema
# 来源：Dashboard 右上头像 → Account → Access Tokens → 新建
# 安全：可随时撤销，权限比 DB_URL 窄
SUPABASE_ACCESS_TOKEN=<sbp_xxxxxxxxxxxxxxxx>

# ── 飞书机器人 ──
FEISHU_WEBHOOK_URL=<飞书自定义机器人 webhook 地址>

# ── Cron 接口鉴权（两个填同一个值） ──
CRON_SECRET=<自定义随机字符串>
REMIND_SECRET=<自定义随机字符串>

# ── AI 接口（站内 AI 助手） ──
AI_BASE_URL=https://api.zhongzhuan.win/v1
AI_API_KEY=<AI 服务商提供的 key>
AI_MODEL=claude-opus-4-6
